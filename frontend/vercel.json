{
    "version": 2,
    "name": "alpa-saas-unificado",
    "cleanUrls": true,
    "framework": null,
    "installCommand": "npm install",
    "buildCommand": null,
    "outputDirectory": ".",
    "trailingSlash": true,
    "rewrites": [
        {
            "source": "/contabilidad",
            "destination": "/modules/contabilidad/index.html"
        },
        {
            "source": "/directorio",
            "destination": "/modules/directorio/index.html"
        },
        {
            "source": "/inventario",
            "destination": "/modules/inventario/index.html"
        },
        {
            "source": "/leads",
            "destination": "/modules/leads/index.html"
        },
        {
            "source": "/dashboard",
            "destination": "/modules/dashboard/index.html"
        },
        {
            "source": "/cotizaciones",
            "destination": "/modules/cotizador/index.html"
        },
        {
            "source": "/ordenes",
            "destination": "/modules/ordenes/index.html"
        },
        {
            "source": "/estados_pago",
            "destination": "/modules/estados_pago/index.html"
        }
    ]
}