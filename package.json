{
    "name": "agent-saas-reload",
    "version": "1.0.0",
    "description": "Unified AI-Agent Powered SaaS Platform",
    "scripts": {
        "install:all": "npm install && cd frontend && npm install && cd ../backend && python -m venv venv && .\\venv\\Scripts\\activate && pip install -r requirements.txt",
        "dev:frontend": "cd frontend && npm start",
        "dev:backend": "cd backend && .\\venv\\Scripts\\activate && uvicorn main:app --reload --port 8000",
        "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\""
    },
    "devDependencies": {
        "concurrently": "^8.2.2",
        "prisma": "^5.10.0"
    },
    "dependencies": {
        "@prisma/client": "^5.10.0"
    }
}
