{
  "version": 2,
  "cleanUrls": false,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=0, stale-while-revalidate=0"
        }
      ]
    },
    {
      "source": "/(.*).js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=0, no-cache, no-store"
        }
      ]
    }
  ],
  "builds": [
    {
      "src": "backend/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/main.py"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/frontend/assets/$1"
    },
    {
      "source": "/modules/(.*)",
      "destination": "/frontend/modules/$1"
    },
    {
      "source": "/components/(.*)",
      "destination": "/frontend/components/$1"
    },
    {
      "source": "/ventas/:file",
      "destination": "/frontend/ventas/:file"
    },
    {
      "source": "/blog",
      "destination": "/frontend/blog/index.html"
    },
    {
      "source": "/blog/:file",
      "destination": "/frontend/blog/:file"
    },
    {
      "source": "/upgrade",
      "destination": "/frontend/upgrade.html"
    },
    {
      "source": "/settings",
      "destination": "/frontend/settings.html"
    },
    {
      "source": "/onboarding",
      "destination": "/frontend/onboarding.html"
    },
    {
      "source": "/register",
      "destination": "/frontend/register.html"
    },
    {
      "source": "/register.html",
      "destination": "/frontend/register.html"
    },
    {
      "source": "/privacidad",
      "destination": "/frontend/privacidad.html"
    },
    {
      "source": "/privacidad.html",
      "destination": "/frontend/privacidad.html"
    },
    {
      "source": "/admin",
      "destination": "/frontend/admin.html"
    },
    {
      "source": "/admin.html",
      "destination": "/frontend/admin.html"
    },
    {
      "source": "/app.html",
      "destination": "/frontend/app.html"
    },
    {
      "source": "/app",
      "destination": "/frontend/app.html"
    },
    {
      "source": "/",
      "destination": "/frontend/index.html"
    }
  ]
}