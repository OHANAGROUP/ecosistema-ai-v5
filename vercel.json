{
    "version": 2,
    "cleanUrls": true,
    "trailingSlash": false,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/backend/main.py"
        },
        {
            "source": "/assets/(.*)",
            "destination": "/frontend/assets/$1"
        },
        {
            "source": "/modules/(.*)",
            "destination": "/frontend/modules/$1"
        },
        {
            "source": "/v4-app.html",
            "destination": "/v4-app.html"
        },
        {
            "source": "/index.html",
            "destination": "/index.html"
        }
    ]
}