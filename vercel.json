    "version": 2,
    "cleanUrls": false,
    "trailingSlash": false,
    "builds": [
        {
            "src": "backend/main.py",
            "use": "@vercel/python"
        },
        {
            "src": "frontend/**",
            "use": "@vercel/static"
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "dest": "backend/main.py"
        },
        {
            "source": "/contabilidad",
            "dest": "/frontend/modules/contabilidad/index.html"
        },
        {
            "source": "/directorio",
            "dest": "/frontend/modules/directorio/index.html"
        },
        {
            "source": "/inventario",
            "dest": "/frontend/modules/inventario/index.html"
        },
        {
            "source": "/leads",
            "dest": "/frontend/modules/leads/index.html"
        },
        {
            "source": "/dashboard",
            "dest": "/frontend/modules/dashboard/index.html"
        },
        {
            "source": "/cotizaciones",
            "dest": "/frontend/modules/cotizador/index.html"
        },
        {
            "source": "/ordenes",
            "dest": "/frontend/modules/ordenes/index.html"
        },
        {
            "source": "/(.*)",
            "dest": "/frontend/$1"
        }
    ]
}