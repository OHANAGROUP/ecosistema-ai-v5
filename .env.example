# ════════════════════════════════════════════════════════════════
# AgentOS v5.0 — Railway Environment Variables Example
# ════════════════════════════════════════════════════════════════

# --- CORE ---
PORT=8080
ENVIRONMENT=production
CRON_SECRET=                   # Generar: openssl rand -hex 32

# --- SUPABASE ---
SUPABASE_URL=                  # URL de tu proyecto Supabase
SUPABASE_KEY=                  # Service Role Key (secret)

# --- AI AGENTS ---
ANTHROPIC_API_KEY=             # Key de console.anthropic.com
ADMIN_ORG_ID=                  # ID de la organización "MD Asesorías Limitada"

# --- EMAILS (RESEND) ---
RESEND_API_KEY=                # Key de resend.com
DEFAULT_FROM_EMAIL=            # ej: contacto@alpa.cl

# --- BILLING (STRIPE) ---
STRIPE_SECRET_KEY=             # Sk_live_... o sk_test_...
STRIPE_WEBHOOK_SECRET=         # Whsec_...
STRIPE_PRICE_STARTER=          # ID del precio en Stripe
STRIPE_PRICE_EMPRESA=          # ID del precio en Stripe

# --- MONITORING ---
SLACK_WEBHOOK_URL=             # Opcional para alertas críticas
